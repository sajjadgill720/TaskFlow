# Supabase (required for auth / data)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Public app / API base URL — no trailing slash. Used for absolute links (e.g. ticket share URLs) and apiFetch().
# Local Vite:
# VITE_API_BASE_URL=http://localhost:5173
# Production:
# VITE_API_BASE_URL=https://task-flow-five-vert.vercel.app
# If omitted, the app uses window.location.origin in the browser.
